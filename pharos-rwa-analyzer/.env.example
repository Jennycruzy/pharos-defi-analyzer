# Pharos RWA Analyzer — environment (all optional; sensible defaults baked in)

# Override the Pharos mainnet RPC if you have a private/faster endpoint.
# Default: https://rpc.pharos.xyz  (verified chain id 1672)
PHAROS_RPC_URL=

# OPTIONAL: a Pharos Watch API key unlocks the live NAV/depeg API layer.
# Request a self-serve key at https://pharos.watch/api/  (shape: ph_live_<hex>_<secret>)
# Without it, the `nav` layer still works using on-chain share-price/oracle drift,
# and clearly labels the API portion as unavailable. Never required.
PHAROS_WATCH_API_KEY=

# The wallet to analyze by default. CLI --address always overrides this.
# Default below is the verified owner/demo wallet (deposited into Tulipa).
DEFAULT_ADDRESS=0x0Ac6bf160e208e67AF06d7F00c92AEfBbf089f95

# ─────────────────────────────────────────────────────────────────────────────
# ACTUATOR (write skill) — only needed when you actually SIGN/SEND actions.
# The read analyzer above needs none of these.
# ─────────────────────────────────────────────────────────────────────────────

# Private key of the OWNER EOA that controls the Safe smart account.
# Required ONLY for `act ... --execute` (and for real simulation). The actuator
# defaults to a no-broadcast dry run that doesn't need a key. NEVER commit this,
# and NEVER pass a key as a CLI argument — it is read from this env var only.
PHAROS_SIGNER_KEY=

# OPTIONAL deployer key for `npm run deploy:modules` — a ONE-TIME, chain-level op
# that lands Safe4337Module + SafeModuleSetup at their canonical addresses on Pharos
# (deterministic CREATE2). Needs native gas. Kept separate from PHAROS_SIGNER_KEY so
# the privileged deploy is always an explicit, deliberate step. NEVER commit this.
PHAROS_DEPLOYER_KEY=

# OPTIONAL ERC-4337 bundler RPC URL. If set, UserOps are sent via
# eth_sendUserOperation. Pharos has no public bundler yet, so when this is empty
# the actuator self-bundles via EntryPoint.handleOps() from the signer EOA.
PHAROS_BUNDLER_URL=

# OPTIONAL: salt for deriving the Safe address (default 0 = your primary account).
PHAROS_SAFE_SALT=

# OPTIONAL safety rails (sensible defaults baked in; see config.ts WRITE_GUARDS).
# MIN_HEALTH_FACTOR floors how risky an action may leave a borrow position (>=1.2).
MIN_HEALTH_FACTOR=
# MAX_SPEND_USD caps the USD value any single action may move (override per-call with --max-spend).
MAX_SPEND_USD=
